# Roblox Sentinel Configuration
# 
# SECURITY: Never commit this file to Git!
# This is a TEMPLATE file. Copy it to .env and fill in your values.
#
# On Windows CMD:
#   set DISCORD_WEBHOOK=your_webhook_url_here
#
# On Windows PowerShell:
#   $env:DISCORD_WEBHOOK="your_webhook_url_here"
#
# On Mac/Linux:
#   export DISCORD_WEBHOOK="your_webhook_url_here"

DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
